<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - GLH Producers</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("GLH Producers", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                @{
                    bool isLoggedIn = Request.Cookies["authenticated"] != null;
                    string fullName = Session["FullName"] as string;
                    string role = Session["Role"] as string;
                    int points = Session["Points"] == null ? 0 : Convert.ToInt32(Session["Points"]);
                    int basketCount = 0;
                    var basket = Session["Basket"] as System.Collections.Generic.List<GLH_producers.Models.BasketItem>;

                    if (basket != null)
                    {
                        foreach (var item in basket)
                        {
                            basketCount += item.Quantity;
                        }
                    }
                }

                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Products", "Index", "Products", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Basket (" + basketCount + ")", "Index", "Basket", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Order History", "History", "Orders", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    @if (role == "Producer")
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Producer Dashboard", "Dashboard", "Producer", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    <li class="nav-item">
                        @Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                </ul>

                <ul class="navbar-nav">
                    @if (!isLoggedIn)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Register", "Register", "Account", new { area = "" }, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Login", "Login", "Account", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        if (!string.IsNullOrEmpty(fullName))
                        {
                            <li class="nav-item">
                                <span class="nav-link">Hi, @Html.Encode(fullName)</span>
                            </li>
                        }

                        <li class="nav-item">
                            <span class="nav-link">Points: @points</span>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Logout", "Logout", "Account", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Love GLH Producers</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
