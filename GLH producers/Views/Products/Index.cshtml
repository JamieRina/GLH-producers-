@model System.Collections.Generic.List<GLH_producers.Models.ProductModel>

@{
    ViewBag.Title = "Products";
}

<h2>Products</h2>
<p>This page lets visitors and customers browse the local products that are currently available to order.</p>

@if (ViewBag.Message != null)
{
    <div class="alert alert-info">@ViewBag.Message</div>
}

@if (Model.Count == 0)
{
    <p>No products are available at the moment.</p>
}
else
{
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h4>@Html.Encode(product.Name)</h4>
                        <p><strong>Category:</strong> @Html.Encode(product.Category)</p>
                        <p>@Html.Encode(product.Description)</p>
                        <p><strong>Price:</strong> @product.Price.ToString("C")</p>
                        <p><strong>Available stock:</strong> @product.Stock</p>

                        <p>
                            @Html.ActionLink("View details", "Details", "Products", new { id = product.ProductId }, new { @class = "btn btn-secondary btn-sm" })
                        </p>

                        @using (Html.BeginForm("Add", "Basket", FormMethod.Post))
                        {
                            @Html.Hidden("id", product.ProductId)
                            <label for="quantity-@product.ProductId">Quantity</label>
                            <input id="quantity-@product.ProductId" class="form-control mb-2" type="number" name="quantity" value="1" min="1" max="@product.Stock" />
                            <button type="submit" class="btn btn-primary btn-sm">Add to basket</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
