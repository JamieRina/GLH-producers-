@model GLH_producers.Models.HomeIndexViewModel

@{
    ViewBag.Title = "Home Page";
}

<main>
    <h2>Welcome to GLH Producers</h2>
    <p>
        GLH Producers helps local customers find fresh products from nearby producers.
        Customers can browse available products, add them to a basket, and place orders
        for collection or delivery.
    </p>

    <p>
        This homepage gives a simple preview of the shop and links users to the main product
        browsing page.
    </p>

    <p>
        @Html.ActionLink("Browse all products", "Index", "Products", null, new { @class = "btn btn-primary" })
        @Html.ActionLink("View basket", "Index", "Basket", null, new { @class = "btn btn-secondary" })
    </p>

    <h3>Featured Products</h3>

    @if (Model.FeaturedProducts.Count == 0)
    {
        <p>No products are currently available.</p>
    }
    else
    {
        <div class="row">
            @foreach (var product in Model.FeaturedProducts)
            {
                <div class="col-md-3 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h4>@Html.Encode(product.Name)</h4>
                            <p>@Html.Encode(product.Category)</p>
                            <p><strong>@product.Price.ToString("C")</strong></p>
                            <p>Stock: @product.Stock</p>

                            @using (Html.BeginForm("Add", "Basket", FormMethod.Post))
                            {
                                @Html.Hidden("id", product.ProductId)
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-primary btn-sm">Add to basket</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</main>
